{
  "name": "nuxt-qrcode",
  "version": "0.4.9",
  "description": "A Nuxt module to provide support for QR Code generation and read.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandros94/nuxt-qrcode.git"
  },
  "homepage": "https://qrcode.s94.dev",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ]
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "build": "pnpm prepack",
    "dev": "nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground && nuxt prepare docs",
    "docs": "nuxt dev docs",
    "docs:build": "nuxt build docs",
    "docs:preview": "nuxt preview docs",
    "release": "pnpm lint && pnpm typecheck && pnpm test && pnpm prepack && changelogen --release --push",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "eslint . --fix",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest watch",
    "typecheck": "vue-tsc --noEmit && nuxt typecheck playground && nuxt typecheck docs"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "@vueuse/core": "^14.1.0",
    "defu": "^6.1.6",
    "uqr": "^0.1.2",
    "vue-qrcode-reader": "^5.7.3"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.1",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/test-utils": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "changelogen": "^0.6.2",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.4",
    "nuxt": "^4.4.2",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "resolutions": {
    "nuxt-qrcode": "workspace:*"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
